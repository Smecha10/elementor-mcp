          "settings": {
            "html": "<div style=\"display:flex;justify-content:center;gap:16px;margin-bottom:48px;\">\n  <button id=\"tab-presencial\" onclick=\"showDate('presencial')\" style=\"padding:12px 32px;border-radius:9999px;font-family:Obvia,sans-serif;font-weight:900;font-size:13px;text-transform:uppercase;letter-spacing:0.15em;background:#83CE00;color:#021024;border:1px solid #83CE00;cursor:pointer;box-shadow:0 0 20px rgba(131,206,0,0.4);\">Presencial</button>\n  <button id=\"tab-virtual\" onclick=\"showDate('virtual')\" style=\"padding:12px 32px;border-radius:9999px;font-family:Obvia,sans-serif;font-weight:900;font-size:13px;text-transform:uppercase;letter-spacing:0.15em;background:transparent;color:#8899aa;border:1px solid rgba(255,255,255,0.1);cursor:pointer;\">Virtual</button>\n</div>\n\n<div id=\"card-presencial\" style=\"max-width:640px;margin:0 auto;border-radius:24px;padding:40px;background:rgba(5,24,51,0.8);backdrop-filter:blur(12px);border:1px solid rgba(131,206,0,0.3);box-shadow:0 0 40px rgba(131,206,0,0.15);position:relative;overflow:hidden;\">\n  <div style=\"position:absolute;right:-40px;bottom:-40px;font-size:192px;opacity:0.1;color:#83CE00;\">\ud83d\udccd</div>\n  <div style=\"display:flex;align-items:center;gap:16px;margin-bottom:40px;position:relative;z-index:1;\">\n    <div style=\"width:56px;height:56px;border-radius:16px;background:rgba(131,206,0,0.2);border:1px solid rgba(131,206,0,0.3);display:flex;align-items:center;justify-content:center;font-size:28px;\">\ud83d\udccd</div>\n    <div>\n      <h3 style=\"font-family:Obvia,sans-serif;font-weight:900;font-size:28px;text-transform:uppercase;color:#fff;margin:0;\">Edici\u00f3n Presencial</h3>\n      <p style=\"font-family:Obvia,sans-serif;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.1em;color:#83CE00;margin:4px 0 0 0;\">Santo Domingo, RD</p>\n    </div>\n  </div>\n  <ul style=\"list-style:none;padding:0;margin:0 0 40px 0;display:flex;flex-direction:column;gap:24px;\">\n    <li style=\"display:flex;align-items:center;gap:16px;font-family:Obvia,sans-serif;font-weight:700;font-size:17px;color:#c5ecff;\">\n      <div style=\"width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:24px;\">\ud83d\udcc5</div>\n      <div><span style=\"display:block;font-size:11px;text-transform:uppercase;letter-spacing:0.15em;color:#8899aa;margin-bottom:2px;\">Fecha</span>20 de mayo, 2026</div>\n    </li>\n    <li style=\"display:flex;align-items:center;gap:16px;font-family:Obvia,sans-serif;font-weight:700;font-size:17px;color:#c5ecff;\">\n      <div style=\"width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:24px;\">\ud83d\udd56</div>\n      <div><span style=\"display:block;font-size:11px;text-transform:uppercase;letter-spacing:0.15em;color:#8899aa;margin-bottom:2px;\">Hora</span>7:00 PM</div>\n    </li>\n    <li style=\"display:flex;align-items:center;gap:16px;font-family:Obvia,sans-serif;font-weight:700;font-size:17px;color:#c5ecff;\">\n      <div style=\"width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:24px;\">\ud83d\udccd</div>\n      <div><span style=\"display:block;font-size:11px;text-transform:uppercase;letter-spacing:0.15em;color:#8899aa;margin-bottom:2px;\">Lugar</span>Velvet Room</div>\n    </li>\n  </ul>\n  <a href=\"https://forms.gle/matdrFatkh6VSshCA\" target=\"_blank\" style=\"display:block;text-align:center;padding:16px 32px;border-radius:16px;font-family:Obvia,sans-serif;font-weight:900;font-size:14px;text-transform:uppercase;letter-spacing:0.15em;background:#83CE00;color:#021024;text-decoration:none;box-shadow:0 0 30px rgba(131,206,0,0.5);\">Registrarme (Presencial)</a>\n</div>\n\n<div id=\"card-virtual\" style=\"max-width:640px;margin:0 auto;border-radius:24px;padding:40px;background:rgba(5,24,51,0.8);backdrop-filter:blur(12px);border:1px solid rgba(0,229,255,0.3);box-shadow:0 0 40px rgba(0,229,255,0.15);position:relative;overflow:hidden;display:none;\">\n  <div style=\"position:absolute;right:-40px;bottom:-40px;font-size:192px;opacity:0.1;color:#00e5ff;\">\ud83c\udf10</div>\n  <div style=\"display:flex;align-items:center;gap:16px;margin-bottom:40px;position:relative;z-index:1;\">\n    <div style=\"width:56px;height:56px;border-radius:16px;background:rgba(0,229,255,0.2);border:1px solid rgba(0,229,255,0.3);display:flex;align-items:center;justify-content:center;font-size:28px;\">\ud83c\udf10</div>\n    <div>\n      <h3 style=\"font-family:Obvia,sans-serif;font-weight:900;font-size:28px;text-transform:uppercase;color:#fff;margin:0;\">Edici\u00f3n Virtual</h3>\n      <p style=\"font-family:Obvia,sans-serif;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.1em;color:#00e5ff;margin:4px 0 0 0;\">Transmisi\u00f3n Online</p>\n    </div>\n  </div>\n  <ul style=\"list-style:none;padding:0;margin:0 0 40px 0;display:flex;flex-direction:column;gap:24px;\">\n    <li style=\"display:flex;align-items:center;gap:16px;font-family:Obvia,sans-serif;font-weight:700;font-size:17px;color:#c5ecff;\">\n      <div style=\"width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:24px;\">\ud83d\udcc5</div>\n      <div><span style=\"display:block;font-size:11px;text-transform:uppercase;letter-spacing:0.15em;color:#8899aa;margin-bottom:2px;\">Fecha</span>26 de mayo, 2026</div>\n    </li>\n    <li style=\"display:flex;align-items:center;gap:16px;font-family:Obvia,sans-serif;font-weight:700;font-size:17px;color:#c5ecff;\">\n      <div style=\"width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:24px;\">\ud83d\udd56</div>\n      <div><span style=\"display:block;font-size:11px;text-transform:uppercase;letter-spacing:0.15em;color:#8899aa;margin-bottom:2px;\">Hora</span>7:00 PM (Hora RD)</div>\n    </li>\n    <li style=\"display:flex;align-items:center;gap:16px;font-family:Obvia,sans-serif;font-weight:700;font-size:17px;color:#c5ecff;\">\n      <div style=\"width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:24px;\">\ud83c\udf10</div>\n      <div><span style=\"display:block;font-size:11px;text-transform:uppercase;letter-spacing:0.15em;color:#8899aa;margin-bottom:2px;\">Canal</span>Meet + Streaming Ducktape</div>\n    </li>\n  </ul>\n  <a href=\"https://forms.gle/matdrFatkh6VSshCA\" target=\"_blank\" style=\"display:block;text-align:center;padding:16px 32px;border-radius:16px;font-family:Obvia,sans-serif;font-weight:900;font-size:14px;text-transform:uppercase;letter-spacing:0.15em;background:#00e5ff;color:#021024;text-decoration:none;box-shadow:0 0 30px rgba(0,229,255,0.5);\">Registrarme (Virtual)</a>\n</div>\n\n<script>\nfunction showDate(tab){\n  var pc=document.getElementById('card-presencial');\n  var vc=document.getElementById('card-virtual');\n  var pb=document.getElementById('tab-presencial');\n  var vb=document.getElementById('tab-virtual');\n  if(tab==='presencial'){\n    pc.style.display='block';vc.style.display='none';\n    pb.style.background='#83CE00';pb.style.color='#021024';pb.style.boxShadow='0 0 20px rgba(131,206,0,0.4)';\n    vb.style.background='transparent';vb.style.color='#8899aa';vb.style.boxShadow='none';\n  } else {\n    pc.style.display='none';vc.style.display='block';\n    vb.style.background='#00e5ff';vb.style.color='#021024';vb.style.boxShadow='0 0 20px rgba(0,229,255,0.4)';\n    pb.style.background='transparent';pb.style.color='#8899aa';pb.style.boxShadow='none';\n  }\n}\n</script>",
