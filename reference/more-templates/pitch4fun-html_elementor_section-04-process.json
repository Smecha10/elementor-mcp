            {
              "id": "wrwu5ewp",
              "elType": "widget",
              "isInner": false,
              "isLocked": false,
              "settings": {
                "html": "<div style=\"display:flex;flex-wrap:wrap;justify-content:center;gap:48px;width:100%;max-width:1100px;\">\n  <div style=\"display:flex;flex-direction:column;align-items:center;text-align:center;flex:1;min-width:140px;max-width:200px;\">\n    <div style=\"width:80px;height:80px;border-radius:50%;border:2px solid #00e5ff;display:flex;align-items:center;justify-content:center;font-family:Obvia,sans-serif;font-weight:900;font-size:28px;color:#00e5ff;background:#021024;margin-bottom:24px;box-shadow:0 0 20px rgba(0,229,255,0.3);\">1</div>\n    <h4 style=\"font-family:Obvia,sans-serif;font-weight:900;font-size:16px;text-transform:uppercase;color:#fff;margin:0 0 12px 0;line-height:1.2;\">Pitch en autoplay</h4>\n    <p style=\"font-family:Obvia,sans-serif;font-size:13px;color:#8899aa;margin:0;line-height:1.5;\">10 slides, 30s c/u. 5 min totales. No se pausa.</p>\n  </div>\n  <div style=\"display:flex;flex-direction:column;align-items:center;text-align:center;flex:1;min-width:140px;max-width:200px;\">\n    <div style=\"width:80px;height:80px;border-radius:50%;border:2px solid #8aff00;display:flex;align-items:center;justify-content:center;font-family:Obvia,sans-serif;font-weight:900;font-size:28px;color:#8aff00;background:#021024;margin-bottom:24px;box-shadow:0 0 20px rgba(138,255,0,0.3);\">2</div>\n    <h4 style=\"font-family:Obvia,sans-serif;font-weight:900;font-size:16px;text-transform:uppercase;color:#fff;margin:0 0 12px 0;line-height:1.2;\">Slide 10: tu ASK</h4>\n    <p style=\"font-family:Obvia,sans-serif;font-size:13px;color:#8899aa;margin:0;line-height:1.5;\">\u00bfQu\u00e9 necesitas? Talento, inversi\u00f3n... Es obligatorio.</p>\n  </div>\n  <div style=\"display:flex;flex-direction:column;align-items:center;text-align:center;flex:1;min-width:140px;max-width:200px;\">\n    <div style=\"width:80px;height:80px;border-radius:50%;border:2px solid #00e5ff;display:flex;align-items:center;justify-content:center;font-family:Obvia,sans-serif;font-weight:900;font-size:28px;color:#00e5ff;background:#021024;margin-bottom:24px;box-shadow:0 0 20px rgba(0,229,255,0.3);\">3</div>\n    <h4 style=\"font-family:Obvia,sans-serif;font-weight:900;font-size:16px;text-transform:uppercase;color:#fff;margin:0 0 12px 0;line-height:1.2;\">Panel 3\u00d760s</h4>\n    <p style=\"font-family:Obvia,sans-serif;font-size:13px;color:#8899aa;margin:0;line-height:1.5;\">Feedback cronometrado sin rodeos. Acci\u00f3n pura.</p>\n  </div>\n  <div style=\"display:flex;flex-direction:column;align-items:center;text-align:center;flex:1;min-width:140px;max-width:200px;\">\n    <div style=\"width:80px;height:80px;border-radius:50%;border:2px solid #8aff00;display:flex;align-items:center;justify-content:center;font-family:Obvia,sans-serif;font-weight:900;font-size:28px;color:#8aff00;background:#021024;margin-bottom:24px;box-shadow:0 0 20px rgba(138,255,0,0.3);\">4</div>\n    <h4 style=\"font-family:Obvia,sans-serif;font-weight:900;font-size:16px;text-transform:uppercase;color:#fff;margin:0 0 12px 0;line-height:1.2;\">Votaci\u00f3n p\u00fablico</h4>\n    <p style=\"font-family:Obvia,sans-serif;font-size:13px;color:#8899aa;margin:0;line-height:1.5;\">1 voto por correo registrado. Simple y real.</p>\n  </div>\n  <div style=\"display:flex;flex-direction:column;align-items:center;text-align:center;flex:1;min-width:140px;max-width:200px;\">\n    <div style=\"width:80px;height:80px;border-radius:50%;border:2px solid #00e5ff;display:flex;align-items:center;justify-content:center;font-family:Obvia,sans-serif;font-weight:900;font-size:28px;color:#00e5ff;background:#021024;margin-bottom:24px;box-shadow:0 0 20px rgba(0,229,255,0.3);\">5</div>\n    <h4 style=\"font-family:Obvia,sans-serif;font-weight:900;font-size:16px;text-transform:uppercase;color:#fff;margin:0 0 12px 0;line-height:1.2;\">Wall of Asks</h4>\n    <p style=\"font-family:Obvia,sans-serif;font-size:13px;color:#8899aa;margin:0;line-height:1.5;\">La comunidad conecta para cumplir tus pedidos.</p>\n  </div>\n</div>",
