                    "html": "<div style=\"position:relative;padding:2px;border-radius:32px;background:linear-gradient(135deg,#00e5ff,#83CE00);max-width:220px;width:100%;\">\n  <div style=\"background:rgba(2,16,36,0.9);backdrop-filter:blur(12px);border-radius:32px;border:1px solid rgba(255,255,255,0.1);padding:20px 32px 20px 32px;text-align:center;\">\n    <div style=\"font-family:Obvia,sans-serif;font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:0.3em;color:#83CE00;margin-bottom:16px;\">20 MAYO</div>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px 8px;\">\n      <div style=\"display:flex;flex-direction:column;align-items:center;\">\n        <span style=\"font-family:Obvia,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.4);margin-bottom:4px;\">D\u00edas</span>\n        <span id=\"p4f-days\" style=\"font-family:Obvia,sans-serif;font-size:40px;font-weight:900;color:#fff;text-shadow:0 0 12px rgba(131,206,0,0.8);line-height:1;\">00</span>\n      </div>\n      <div style=\"display:flex;flex-direction:column;align-items:center;\">\n        <span style=\"font-family:Obvia,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.4);margin-bottom:4px;\">Hrs</span>\n        <span id=\"p4f-hours\" style=\"font-family:Obvia,sans-serif;font-size:40px;font-weight:900;color:#fff;text-shadow:0 0 12px rgba(131,206,0,0.8);line-height:1;\">00</span>\n      </div>\n      <div style=\"display:flex;flex-direction:column;align-items:center;\">\n        <span style=\"font-family:Obvia,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.4);margin-bottom:4px;\">Min</span>\n        <span id=\"p4f-minutes\" style=\"font-family:Obvia,sans-serif;font-size:40px;font-weight:900;color:#fff;text-shadow:0 0 12px rgba(131,206,0,0.8);line-height:1;\">00</span>\n      </div>\n      <div style=\"display:flex;flex-direction:column;align-items:center;\">\n        <span style=\"font-family:Obvia,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.4);margin-bottom:4px;\">Seg</span>\n        <span id=\"p4f-seconds\" style=\"font-family:Obvia,sans-serif;font-size:40px;font-weight:900;color:#83CE00;text-shadow:0 0 12px rgba(131,206,0,0.8);line-height:1;\">00</span>\n      </div>\n    </div>\n  </div>\n</div>\n<script>\n(function(){\n  var target = new Date(\"2026-05-20T19:00:00\");\n  function pad(n){return String(n).padStart(2,\"0\");}\n  function update(){\n    var now=new Date(), diff=target-now;\n    if(diff<=0){diff=0;}\n    document.getElementById(\"p4f-days\").textContent=pad(Math.floor(diff/86400000));\n    document.getElementById(\"p4f-hours\").textContent=pad(Math.floor((diff/3600000)%24));\n    document.getElementById(\"p4f-minutes\").textContent=pad(Math.floor((diff/60000)%60));\n    document.getElementById(\"p4f-seconds\").textContent=pad(Math.floor((diff/1000)%60));\n  }\n  update();setInterval(update,1000);\n})();\n</script>",
