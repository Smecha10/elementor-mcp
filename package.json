{
  "name": "@smecha10/elementor-mcp",
  "version": "0.6.0",
  "description": "MCP server for Elementor WordPress \u2014 compile blueprints into import-ready Elementor v4 JSON with 30 templates, 51 widgets, dual format output, motion effects, Theme Builder support, and schema learning.",
  "type": "module",
  "bin": {
    "elementor-mcp": "dist/server.js"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "selftest": "node dist/selftest.js",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "elementor",
    "wordpress",
    "page-builder",
    "ai",
    "model-context-protocol",
    "blueprint",
    "website-builder",
    "atomic-widgets",
    "elementor-v4"
  ],
  "author": "Smecha10",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Smecha10/elementor-mcp.git"
  },
  "homepage": "https://github.com/Smecha10/elementor-mcp#readme",
  "bugs": {
    "url": "https://github.com/Smecha10/elementor-mcp/issues"
  },
  "files": [
    "dist/",
    "docs/",
    "examples/",
    "reference/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}